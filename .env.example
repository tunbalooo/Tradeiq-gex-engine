APP_NAME=TradeIQ GEX Engine
APP_ENV=development
DATABASE_URL=sqlite:///./data/tradeiq.db
SIMULATED_MODE=true
SIMULATION_SYMBOL=NQ
SIMULATION_START_PRICE=24892.25
UPDATE_INTERVAL_SECONDS=2

# Live mode — set SIMULATED_MODE=false to use real (free/delayed) data.
# Price: MNQ=F / NQ=F via yfinance. Options: QQQ chain, scaled to NQ points
# (see backend/services/live_options.py for why QQQ is the free proxy).
LIVE_PRICE_SYMBOL=MNQ=F
LIVE_OPTIONS_SYMBOL=QQQ
LIVE_REFRESH_SECONDS=30

# Databento (native CME NQ data — next upgrade). Key goes in your local .env
# and in Railway variables, NEVER committed. Rotate any key that was ever
# shared in a chat.
DATABENTO_API_KEY=
DATABENTO_DATASET=GLBX.MDP3
# Data provider selector (yfinance today; databento once test passes)
DATA_PROVIDER=yfinance
