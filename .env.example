APP_NAME=TradeIQ GEX Engine
APP_ENV=development
DATABASE_URL=sqlite:///./data/tradeiq.db

DATA_PROVIDER=simulated
SIMULATED_MODE=true
SIMULATION_SYMBOL=NQ
SIMULATION_START_PRICE=24892.25
UPDATE_INTERVAL_SECONDS=2
ENGINE_CYCLE_SECONDS=2

DATABENTO_API_KEY=
DATABENTO_DATASET=GLBX.MDP3
DATABENTO_FUTURES_SYMBOL=NQ.v.0
DATABENTO_OPTIONS_PARENT=NQ.OPT
DATABENTO_HISTORY_DAYS=7
DATABENTO_HISTORY_LIMIT=2400
GEX_REFRESH_SECONDS=300
GEX_REPRICE_SECONDS=30

SETUP_ACTIONABLE_SCORE=75
SETUP_EXPIRY_MINUTES=30
CLUSTER_MIN_SCORE=0.65
CLUSTER_TOLERANCE_ATR=0.25
EVENT_SEQUENCE_MAX_BARS=4
EVENT_MAX_AGE_BARS=12
NQ_TICK_SIZE=0.25

# Protect reset/refresh/settings endpoints on Railway.
ADMIN_TOKEN=
ALLOW_PUBLIC_ADMIN=false
