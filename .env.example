APP_NAME=TradeIQ GEX Engine
APP_ENV=development
DATABASE_URL=sqlite:///./data/tradeiq.db

DATA_PROVIDER=simulated
SIMULATED_MODE=true
DEFAULT_SYMBOL=NQ
UPDATE_INTERVAL_SECONDS=2
ENGINE_CYCLE_SECONDS=2

DATABENTO_API_KEY=
DATABENTO_DATASET=GLBX.MDP3
DATABENTO_HISTORY_DAYS=7
DATABENTO_HISTORY_LIMIT=2400
DATABENTO_MARKET_CACHE_SECONDS=1800
DATABENTO_PREWARM_MARKETS=false
DATABENTO_PREWARM_DELAY_SECONDS=0.5
GEX_REFRESH_SECONDS=300
GEX_REPRICE_SECONDS=30

# Legacy single-symbol settings retained for backwards compatibility only.
SIMULATION_SYMBOL=NQ
DATABENTO_FUTURES_SYMBOL=NQ.v.0
DATABENTO_OPTIONS_PARENT=NQ.OPT

SETUP_ACTIONABLE_SCORE=75
SETUP_EXPIRY_MINUTES=30
CLUSTER_MIN_SCORE=0.65
CLUSTER_TOLERANCE_ATR=0.25
EVENT_SEQUENCE_MAX_BARS=4
EVENT_MAX_AGE_BARS=12

# Protect reset/refresh/settings endpoints on Railway.
ADMIN_TOKEN=
ALLOW_PUBLIC_ADMIN=false

# Finnhub market news (server-side only).
FINNHUB_API_KEY=
FINNHUB_NEWS_REFRESH_SECONDS=300
FINNHUB_REQUEST_TIMEOUT_SECONDS=12

# Claude market analyst (server-side only; never put the key in frontend files).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5
CLAUDE_ANALYSIS_ENABLED=false
CLAUDE_ANALYSIS_INTERVAL_SECONDS=300
CLAUDE_FORCE_MIN_INTERVAL_SECONDS=60
CLAUDE_MAX_OUTPUT_TOKENS=700
CLAUDE_REQUEST_TIMEOUT_SECONDS=60
